{
  "name": "voicebridge-cloud",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "description": "VoiceBridge Phase 1 Cloud YouTube MVP service",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
